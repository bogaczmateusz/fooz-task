{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "fooz-theme/faq-item",
  "version": "1.0.0",
  "title": "FAQ Item",
  "category": "text",
  "icon": "editor-help",
  "description": "A single FAQ item with an editable question and answer.",
  "textdomain": "fooz-theme",
  "parent": ["fooz-theme/faq-accordion"],
  "supports": {
    "html": false,
    "inserter": false,
    "reusable": false
  },
  "attributes": {
    "question": {
      "type": "string",
      "default": ""
    },
    "answer": {
      "type": "string",
      "default": ""
    }
  },
  "editorScript": "file:./index.js"
}
